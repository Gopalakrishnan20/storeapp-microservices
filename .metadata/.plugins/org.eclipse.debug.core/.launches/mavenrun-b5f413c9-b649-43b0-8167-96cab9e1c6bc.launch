<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<launchConfiguration type="org.eclipse.m2e.Maven2LaunchConfigurationType">
    <booleanAttribute key="M2_BATCH" value="false"/>
    <stringAttribute key="M2_GOALS" value="-U archetype:generate"/>
    <listAttribute key="M2_PROPERTIES">
        <listEntry value="archetypeVersion=0.0.2"/>
        <listEntry value="package=com.gk.microservices_store"/>
        <listEntry value="archetypeGroupId=com.github.bjlhx15"/>
        <listEntry value="archetypeArtifactId=maven-archetypes-webapp"/>
        <listEntry value="groupId=com.gk"/>
        <listEntry value="artifactId=microservices-store"/>
        <listEntry value="outputDirectory=D:\EclipseWorkspace\Microservices Projects"/>
        <listEntry value="version=0.0.1-SNAPSHOT"/>
    </listAttribute>
    <booleanAttribute key="M2_SAVE_BEFORE_LAUNCH" value="false"/>
    <booleanAttribute key="org.eclipse.debug.ui.private" value="true"/>
    <stringAttribute key="org.eclipse.jdt.launching.WORKING_DIRECTORY" value="D:\EclipseWorkspace\Microservices Projects"/>
</launchConfiguration>
